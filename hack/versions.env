# Pinned tool versions — the single source of truth, consumed three ways:
#   - shell:    `source hack/versions.env`        (hack/lib.sh)
#   - make:     `include ../hack/versions.env`     (operator/Makefile)
#   - workflows: `grep -v '^#' hack/versions.env >> "$GITHUB_ENV"`
# Keep lines as literal KEY=value (no spaces around =, no interpolation) so all three
# parsers accept the file. Bump a tool here and every consumer follows.
OPERATOR_SDK_VERSION=v1.42.2
OPM_VERSION=v1.51.0
OLM_VERSION=0.28.0
KIND_VERSION=v0.24.0
OPERATOR_MANIFEST_TOOLS_VERSION=v0.12.0
YQ_VERSION=v4.44.3
# Preloaded by .github/actions/olm-kind: KIND_VERSION's default node image — bump
# them together.
KIND_NODE_IMAGE=kindest/node:v1.31.0
GOLANGCI_LINT_VERSION=v2.12.2
