# Compiled binary (built from ./cmd/dotvirt)
/dotvirt

# Local demo launcher (carries env wiring/credentials, not code)
/run-demo.sh

# Local draft store (per-(user,project) staged changes; runtime state)
/.dotvirt-drafts/

# Go build/test artifacts
*.test
*.out
*.prof

# Backups and local dumps
*-backup-*.yaml

# Throwaway preview CatalogSource (per-rc, digest-pinned; written by hack/preview.sh)
/operator/install/catalogsource-preview.yaml

# operator-manifest-tools pin side-output (extract/replace manifests); `make bundle` removes
# them, this covers a manual `pinning pin` run
/operator/references.json
/operator/replacements.json

# Editor/OS
*.swp
